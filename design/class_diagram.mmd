classDiagram
    class Owner {
        +String name
        +int available_minutes
        +String preferences
        +add_task(task)
        +remove_task(task_name)
        +get_tasks()
    }

    class Pet {
        +String name
        +String species
        +int age
        +String notes
        +summary()
    }

    class CareTask {
        +String name
        +int duration_minutes
        +String priority
        +String category
        +bool completed
        +mark_done()
        +edit()
        +to_dict()
    }

    class Scheduler {
        +Owner owner
        +List scheduled_tasks
        +List skipped_tasks
        +generate_plan()
        +explain_plan()
        +get_plan()
    }

    Owner "1" --> "1" Pet : owns
    Owner "1" --> "many" CareTask : manages
    Scheduler "1" --> "1" Owner : uses
